<% if @songs.empty? && @albums.empty? && @authors.empty? %>
  <p class="search-results__empty">No results found.</p>
<% else %>
  <% if @songs.any? %>
    <section class="search-results__group">
      <h3 class="search-results__title">Songs</h3>
      <ul class="search-results__list">
        <% @songs.each do |song| %>
          <li class="search-result">
            <% if song.image.attached? %>
              <%= image_tag song.image, class: "search-result__image", loading: "lazy", alt: "" %>
            <% else %>
              <div class="search-result__image search-result__image--placeholder"></div>
            <% end %>
            <div class="search-result__meta">
              <p class="search-result__name"><%= song.name %></p>
              <p class="search-result__sub">
                Song
                <% if song.authors.any? %>
                  · <%= song.authors.map(&:name).join(", ") %>
                <% end %>
              </p>
            </div>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <% if @albums.any? %>
    <section class="search-results__group">
      <h3 class="search-results__title">Albums</h3>
      <ul class="search-results__list">
        <% @albums.each do |album| %>
          <li class="search-result">
            <% if album.image.attached? %>
              <%= image_tag album.image, class: "search-result__image", loading: "lazy", alt: "" %>
            <% else %>
              <div class="search-result__image search-result__image--placeholder"></div>
            <% end %>
            <div class="search-result__meta">
              <p class="search-result__name"><%= album.name %></p>
              <p class="search-result__sub">Album · <%= album.author.name %></p>
            </div>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <% if @authors.any? %>
    <section class="search-results__group">
      <h3 class="search-results__title">Artists</h3>
      <ul class="search-results__list">
        <% @authors.each do |author| %>
          <li class="search-result">
            <% if author.image.attached? %>
              <%= image_tag author.image, class: "search-result__image search-result__image--round", loading: "lazy", alt: "" %>
            <% else %>
              <div class="search-result__image search-result__image--round search-result__image--placeholder"></div>
            <% end %>
            <div class="search-result__meta">
              <p class="search-result__name"><%= author.name %></p>
              <p class="search-result__sub">Artist</p>
            </div>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>
<% end %>
