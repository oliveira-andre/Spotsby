<%
  song_image_url =
    if @song&.image&.attached?
      url_for(@song.image)
    elsif @song&.album&.image&.attached?
      url_for(@song.album.image)
    end
  song_audio_url = @song&.audio&.attached? ? url_for(@song.audio) : nil
  song_authors = @song ? @song.authors.map(&:name).join(", ") : nil
%>

<div class="player"
     data-controller="player"
     data-player-modal-outlet="#song-details"
     data-player-now-playing-outlet="#minimal-player"
     data-player-song-id-value="<%= @song&.id %>"
     data-player-slug-value="<%= @song&.slug %>"
     data-player-name-value="<%= @song&.name %>"
     data-player-authors-value="<%= song_authors %>"
     data-player-image-url-value="<%= song_image_url %>"
     data-player-audio-url-value="<%= song_audio_url %>">
  <header class="player__header">
    <%= link_to root_path,
                class: "player__icon-btn",
                data: { turbo_stream: true, player_target: "closeLink" },
                aria: { label: "Close player" } do %>
      <%= icon :chevron_down, size: 24 %>
    <% end %>

    <div class="player__header-spacer"></div>

    <button type="button"
            class="player__icon-btn"
            aria-label="Song details"
            data-action="click->player#openDetails">
      <%= icon :dots_vertical, size: 22 %>
    </button>
  </header>

  <main class="player__art-wrap">
    <% if song_image_url %>
      <%= image_tag song_image_url, class: "player__art", alt: @song.name, loading: "lazy" %>
    <% else %>
      <div class="player__art player__art--placeholder"></div>
    <% end %>
  </main>

  <footer class="player__bar">
    <div class="player__track">
      <div class="player__track-text">
        <% if @song&.album %>
          <%= link_to @song.name, album_path(@song.album), class: "player__track-name", data: { turbo_stream: true } %>
        <% else %>
          <p class="player__track-name"><%= @song&.name || "No song playing" %></p>
        <% end %>
        <p class="player__track-artist">
          <%= song_authors || "—" %>
        </p>
      </div>
      <button type="button" class="player__icon-btn player__heart" aria-label="Favorite">
        <%= icon :heart, size: 22 %>
      </button>
    </div>

    <div class="player__progress">
      <input type="range"
             class="player__slider"
             min="0"
             max="100"
             step="0.1"
             value="0"
             aria-label="Seek"
             data-player-target="slider"
             data-action="input->player#seek">
      <div class="player__times">
        <span class="player__time player__time--current"
              data-player-target="currentTime">0:00</span>
        <span class="player__time player__time--total"
              data-player-target="totalTime"
              data-duration-ms="<%= @song&.duration_ms %>">
          <%= @song&.duration_ms ? Time.at(@song.duration_ms / 1000).utc.strftime("%-M:%S") : "0:00" %>
        </span>
      </div>
    </div>

    <div class="player__controls">
      <button type="button" class="player__ctrl" aria-label="Shuffle">
        <%= icon :shuffle, size: 22 %>
      </button>
      <%= button_to previous_players_path,
                    method: :post,
                    class: "player__ctrl",
                    form_class: "player__ctrl-form",
                    aria: { label: "Previous" } do %>
        <%= icon :backward, size: 28 %>
      <% end %>
      <button type="button"
              class="player__ctrl player__ctrl--primary"
              aria-label="Play"
              data-action="click->player#toggle"
              data-player-target="playButton">
        <span data-player-target="playIcon"><%= icon :play, size: 22 %></span>
        <span data-player-target="pauseIcon" hidden><%= icon :pause, size: 22 %></span>
      </button>
      <%= button_to next_players_path,
                    method: :post,
                    class: "player__ctrl",
                    form_class: "player__ctrl-form",
                    aria: { label: "Next" } do %>
        <%= icon :forward, size: 28 %>
      <% end %>
      <button type="button" class="player__ctrl" aria-label="Repeat">
        <%= icon :repeat, size: 22 %>
      </button>
    </div>
  </footer>
</div>

<%= render "shared/modal", id: "song-details", title: "Song details" do %>
  <% if @song %>
    <div class="player__details">
      <% if @song.album&.image&.attached? %>
        <%= image_tag @song.album.image, class: "player__details-thumb", alt: @song.album.name, loading: "lazy" %>
      <% elsif @song.image.attached? %>
        <%= image_tag @song.image, class: "player__details-thumb", alt: @song.name, loading: "lazy" %>
      <% end %>
      <div class="player__details-text">
        <p class="player__details-artist"><%= @song.authors.map(&:name).join(", ") %></p>
        <p class="player__details-album"><%= @song.album&.name %></p>
      </div>
    </div>
  <% else %>
    <p class="player__details-empty">No song playing.</p>
  <% end %>
<% end %>
