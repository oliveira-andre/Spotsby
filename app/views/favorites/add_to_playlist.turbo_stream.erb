<%= turbo_stream.update dom_id(@song, :heart) do %>
  <%= render "shared/song_heart_button",
             song: @song,
             saved: @saved,
             size: @size,
             button_class: @button_class %>
<% end %>

<%= turbo_stream.replace "playlists-modal" do %>
  <%= render "shared/modal", id: "playlists-modal", title: "Select a playlist" %>
<% end %>
