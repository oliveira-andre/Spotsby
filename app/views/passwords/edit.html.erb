<main class="auth">
  <section class="auth__card">
    <%= image_tag "/logo.png", alt: "Spotsby", class: "auth__logo" %>

    <header class="auth__header">
      <h1 class="auth__title">Update your password</h1>
      <p class="auth__subtitle">Choose a new password for your account.</p>
    </header>

    <% if flash[:alert] %>
      <div class="flash flash--alert" role="alert"><%= flash[:alert] %></div>
    <% end %>

    <%= form_with url: password_path(params[:token]), method: :put, class: "form" do |form| %>
      <div class="form-field">
        <%= form.label :password, "New password", class: "label" %>
        <%= form.password_field :password,
              class: "input",
              required: true,
              autocomplete: "new-password",
              placeholder: "Enter new password",
              maxlength: 72 %>
      </div>

      <div class="form-field">
        <%= form.label :password_confirmation, "Confirm password", class: "label" %>
        <%= form.password_field :password_confirmation,
              class: "input",
              required: true,
              autocomplete: "new-password",
              placeholder: "Repeat new password",
              maxlength: 72 %>
      </div>

      <%= form.submit "Update password", class: "btn btn--primary btn--block btn--uppercase btn--lg" %>
    <% end %>

    <div class="auth__footer">
      <p>Remembered your password? <%= link_to "Log in", new_session_path %></p>
    </div>
  </section>
</main>
