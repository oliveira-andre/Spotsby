<main class="auth">
  <section class="auth__card">
    <%= image_tag "/logo.png", alt: "Spotsby", class: "auth__logo" %>

    <header>
      <h1 class="auth__title">Log in to Spotsby</h1>
    </header>

    <% if flash[:alert] %>
      <div class="flash flash--alert" role="alert"><%= flash[:alert] %></div>
    <% end %>

    <% if flash[:notice] %>
      <div class="flash flash--notice" role="status"><%= flash[:notice] %></div>
    <% end %>

    <%= form_with url: session_path, class: "form" do |form| %>
      <div class="form-field">
        <%= form.label :email_address, "Email address", class: "label" %>
        <%= form.email_field :email_address,
              class: "input",
              required: true,
              autofocus: true,
              autocomplete: "username",
              placeholder: "name@email.com",
              value: params[:email_address] %>
      </div>

      <div class="form-field">
        <%= form.label :password, "Password", class: "label" %>
        <%= form.password_field :password,
              class: "input",
              required: true,
              autocomplete: "current-password",
              placeholder: "Password",
              maxlength: 72 %>
      </div>

      <%= form.submit "Log in", class: "btn btn--primary btn--block btn--uppercase btn--lg" %>
    <% end %>

    <div class="auth__footer">
      <%= link_to "Forgot your password?", new_password_path, class: "btn--link" %>
      <p>Don't have an account? <%= link_to "Sign up for Spotsby", new_registration_path %></p>
    </div>
  </section>
</main>
